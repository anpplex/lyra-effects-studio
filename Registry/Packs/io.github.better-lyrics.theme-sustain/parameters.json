{
  "schemaVersion": 1,
  "groups": [
    {
      "id": "typography",
      "label": "Typography",
      "parameters": [
        {
          "id": "lyric-size",
          "label": "Lyric size",
          "control": "length",
          "binding": { "cssVariable": "--blyrics-font-size" },
          "defaultValue": 3,
          "unit": "rem",
          "minimum": 1,
          "maximum": 7,
          "step": 0.1
        },
        {
          "id": "font-weight",
          "label": "Font weight",
          "control": "select",
          "binding": { "cssVariable": "--blyrics-font-weight" },
          "defaultValue": "600",
          "options": [
            { "label": "Regular", "value": "400" },
            { "label": "Medium", "value": "500" },
            { "label": "Semibold", "value": "600" },
            { "label": "Bold", "value": "700" }
          ]
        }
      ]
    },
    {
      "id": "motion-layout",
      "label": "Motion & layout",
      "parameters": [
        {
          "id": "hover-scale",
          "label": "Hover scale",
          "control": "number",
          "binding": { "cssVariable": "--blyrics-hover-scale" },
          "defaultValue": 1.01,
          "minimum": 1,
          "maximum": 1.12,
          "step": 0.01
        },
        {
          "id": "wobble-duration",
          "label": "Wobble duration",
          "control": "number",
          "binding": { "cssVariable": "--blyrics-wobble-duration" },
          "defaultValue": 1,
          "unit": "s",
          "minimum": 0.1,
          "maximum": 3,
          "step": 0.1
        },
        {
          "id": "panel-size",
          "label": "Lyrics panel",
          "control": "length",
          "binding": { "cssVariable": "--blyrics-panel-size" },
          "defaultValue": 50,
          "unit": "%",
          "minimum": 35,
          "maximum": 70,
          "step": 1
        }
      ]
    }
  ]
}
