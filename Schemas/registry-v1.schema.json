{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lyra Theme Registry v1",
  "type": "object",
  "required": ["schemaVersion", "registryId", "name", "generatedAt", "keyId", "packs"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "registryId": { "type": "string" },
    "name": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "keyId": { "type": "string" },
    "packs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "family", "version", "manifestUrl", "downloadUrl", "sha256", "signature", "size", "minimumRuntimeApi"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "family": { "type": "string" },
          "themeId": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$" },
          "version": { "type": "string" },
          "manifestUrl": { "type": "string" },
          "downloadUrl": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "signature": { "type": "string" },
          "size": { "type": "integer", "minimum": 1 },
          "minimumRuntimeApi": { "type": "string" }
        }
      }
    }
  }
}
